{% extends 'base.html.twig' %}

{% block title %}
    Toutes les sorties | {{ parent() }}
{% endblock %}


{% block body %}
    {# affiche tous les sorties #}
    <h1>Toutes les sorties</h1>
    <table class="table-sm table-bordered">
        <thead>
        <tr>
            <th scope="col">Nom de la sortie</th>
            <th scope="col">Date de la sortie</th>
            <th scope="col">Clôture</th>
            <th scope="col">Inscrits/places</th>
            <th scope="col">État</th>
            <th scope="col">Inscrit</th>
            <th scope="col">Organisateur</th>
            <th scope="col">Action</th>
        </tr>
        </thead>
        <tbody>
        {% for sortie in sorties %}
            <tr>
                <td>{{ sortie.nom }}</td>
                <td>{{ sortie.dateHeureDebut | date('d/m/y H:i') }}</td>
                <td>{{ sortie.dateLimiteInscription | date('d/m/Y') }}</td>
                <td>
                    {{ sortie.inscrits|length }} / {{ sortie.nbInscriptionMax }}</td>
                <td>{{ sortie.etat }}</td>
                <td class="text-center">
                    {% if sortie.inscrits|length === sortie.nbInscriptionMax %}
                        X
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_participant_show', {id:sortie.organisateur.id}) }}" title="Détails organisateur">
                        {{ sortie.organisateur.pseudo }}
                    </a>
                </td>
                <td>

                    <a class="btn btn-group-sm btn-primary" href="{{ path('sortie_show', {'id': sortie.id}) }}"
                       title="Détail de la sortie">
                        Afficher
                    </a>

                    {% if app.user and app.user.id == sortie.organisateur.id %}
                        {% if sortie.published == true %}
                            <a class="btn btn-group-sm btn-danger" href="{{ path('sortie_show', {'id': sortie.id}) }}"
                               title="Annuler la sortie">
                                Annuler / à faire
                            </a>
                        {% else %}
                            <a class="btn btn-group-sm btn-success" href="{{ path('sortie_edit', {'id': sortie.id}) }}"
                               title="Modifier la sortie">
                                Modifier / à faire
                            </a>

                            <a class="btn btn-group-sm btn-success" href="{{ path('sortie_show', {'id': sortie.id}) }}"
                               title="Publier la sortie">
                                Publier / à faire
                            </a>

                            <a class="btn btn-group-sm btn-danger" href="{{ path('sortie_show', {'id': sortie.id}) }}"
                               title="Supprimer la sortie">
                                Supprimer / à faire
                            </a
                        {% endif %}
                    {% endif %}



                    {% if sortie.etat.id == 2 %}
                        {% if app.user and app.user in sortie.inscrits %}
                            <a class="btn btn-group-sm btn-primary" href="{{ path('sortie_show', {'id': sortie.id}) }}"
                               title="S'inscrire à la sortie">
                                Se désister / à faire
                            </a>
                        {% else %}
                            <a class="btn btn-group-sm btn-primary" href="{{ path('sortie_show', {'id': sortie.id}) }}"
                               title="S'inscrire à la sortie">
                                S'inscrire / à faire
                            </a>
                        {% endif %}
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucune Sortie programmée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <nav class="mt-3">
        <ul class="pagination">
            {% for p in 1..pages %}
                <li class="page-item {{ p == page ? 'active' }}">
                    <a class="page-link" href="{{ path('sortie_liste', { page: p }) }}">{{ p }}</a>
                </li>
            {% endfor %}
        </ul>
    </nav>

    <a class="btn btn-lg btn-primary" href="{{ path('sortie_create') }}" title="Créer une sortie">
        Créer une sortie
    </a>
{% endblock %}
