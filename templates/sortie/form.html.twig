{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }}{{ titleAndH1 }}
{% endblock %}


{% block section %}
    {{ form_start(form) }}
    <div class="d-flex justify-content-center align-items-center row m-3">
        <div class="col-12 d-flex justify-content-center align-content-around">
            <h1>{{ titleAndH1 }}</h1>
        </div>
        <div class="col-sm-12 col-md-6 justify-content-center align-content-around">
            {{ form_row(form.nom) }}
            {{ form_row(form.dateHeureDebut) }}
            {{ form_row(form.dateLimiteInscription) }}
            {{ form_row(form.nbInscriptionMax) }}
            {{ form_row(form.duree) }}
        </div>
        <div class="col-sm-12 col-md-6 justify-content-center">
            {{ form_row(form.campus) }}
            {{ form_row(form.lieuVille) }}
            {{ form_row(form.lieuCP) }}
            {{ form_row(form.lieuNom) }}
            <button type="button" id="search-place-btn" class="btn btn-sm btn-outline-primary mb-1">Rerchercher</button>
            <div id="places_container">
                <p class="text-secondary">Lancer une recherche sur le ou les lieux de votre sortie en indiquant la ville et un critère de lieu ci-dessus.</p>
                <select name="1" id="1" class="form-switch" multiple>
                    <option value="12">12</option>
                    <option value="13">13</option>
                </select>
            </div>
            {#{{ form_row(form.lieuRue) }}
            {{ form_row(form.lieuCoordonnees) }}#}
        </div>
        <div class="col-12 ustify-content-center align-content-around">
            {{ form_row(form.infosSortie) }}
        </div>
        <div class="row gap-2 justify-content-center align-content-around">
            <div class="col-12 col-sm-2 d-flex justify-content-center">
                {{ form_row(form.enregistrer) }}
            </div>
            <div class="col-12 col-sm-2 d-flex justify-content-center">
                {{ form_row(form.publier) }}
            </div>
            <div class="col-12 col-sm-2 d-flex justify-content-center">
                <div class="mb-3">
                    <a href="{{ path('sortie_liste') }}" class="text-decoration-none text-white">
                        <button type="button" class="btn btn-secondary">
                            Retour à la liste
                        </button>
                    </a>
                </div>
            </div>
            {% if allowRemove %}
                <div class="col-12 col-sm-2 d-flex justify-content-center">
                    {{ form_row(form.supprimer) }}
                </div>
            {% endif %}
        </div>
    </div>
    {{ form_end(form) }}

{% endblock %}

{% block scriptComplementaire %}
    <script src="{{ asset('scripts/findVilleCp.js') }}" defer></script>
    <script src="{{ asset('scripts/googlePlacesSearch.js') }}" defer></script>
{% endblock %}

