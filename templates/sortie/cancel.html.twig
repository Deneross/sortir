{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }}{{ sortie.nom }}
{% endblock %}

{% block section %}
    <h1 class="text-center mb-4">Annuler une sortie</h1>

    <div class="text-center mb-4">
        <span class="badge {{ etatColor }}">{{ sortie.etat.libelle }}</span>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">

                    <div class="row mb-3">
                        <div class="col-sm-5 fw-bold">Nom de la sortie</div>
                        <div class="col-sm-7">{{ sortie.nom }}</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5 fw-bold">Date et heure</div>
                        <div class="col-sm-7">{{ sortie.dateHeureDebut|date('d/m/Y H:i') }}</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5 fw-bold">Campus</div>
                        <div class="col-sm-7">{{ sortie.campus.name }}</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-5 fw-bold">Lieu</div>
                        <div class="col-sm-7">{{ sortie.lieux.current }}</div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-5 fw-bold">Ville</div>
                        <div class="col-sm-7">{{ sortie.lieux.current.ville.name }}</div>
                    </div>

                    {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_row(form.motif) }}
                    </div>

                    <div class="d-flex justify-content-center gap-2">
                        <a href="{{ path('sortie_liste') }}" class="btn btn-secondary">Retour</a>
                        {{ form_widget(form.enregistrer) }}
                    </div>
                    {{ form_end(form) }}

                </div>
            </div>
        </div>
    </div>
{% endblock %}
