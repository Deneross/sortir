{% extends 'base.html.twig' %}

{% block title %}
    {{ sortie.nom}} |{{ parent() }}>
{% endblock %}


{% block body %}
    {# todo: affiche tous les détails #}
    <h1 class="text-center mb-4">Afficher une sortie</h1>

    <!-- infos 2 colonnes -->
    <div class="container mt-5">

        <div class="card shadow-sm">
            <div class="card-body">

                <div class="row">

                    <!-- Colonne gauche -->
                    <div class="col-md-6">

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Nom de la sortie</div>
                            <div class="col-6">{{ sortie.nom }}</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Date et heure</div>
                            <div class="col-6">
                                {{ sortie.dateHeureDebut|date('d/m/Y H:i') }}
                            </div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Date limite</div>
                            <div class="col-6">
                                {{ sortie.dateLimiteInscription|date('d/m/Y H:i') }}
                            </div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Nombre de places</div>
                            <div class="col-6">{{ sortie.nbInscriptionMax }}</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Durée (minutes)</div>
                            <div class="col-6">{{ sortie.duree }}</div>
                        </div>

                    </div>

                    <!-- Colonne droite -->
                    <div class="col-md-6">

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Campus</div>
                            <div class="col-6">sortie.campus.nom</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Ville</div>
                            <div class="col-6">sortie.lieu.ville</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Lieu</div>
                            <div class="col-6">sortie.lieu.nom</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Rue</div>
                            <div class="col-6">sortie.lieu.rue</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Code postal</div>
                            <div class="col-6">sortie.lieu.codePostal</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Latitude / Longitude</div>
                            <div class="col-6">
                                sortie.lieu.latitude / sortie.lieu.longitude
                            </div>
                        </div>

                    </div>

                </div>

                <!-- Description -->
                <hr>

                <div class="mt-3">
                    <h5>Description et infos</h5>
                    <p class="text-muted">
                        {{ sortie.infosSortie }}
                    </p>
                </div>

            </div>
        </div>

    </div>

    <!-- liste participant -->
    <div class="container mt-5">
        <h2>Liste des participants inscrits</h2>
        <table class="table-sm table-bordered">
            <thead>
            <tr>
                <th scope="col">Pseudo</th>
                <th scope="col">Nom</th>
            </tr>
            </thead>
            <tbody>

{#            {% for participant in sortie.participant %}#}
{#                <tr>#}
{#                    <td>#}
{#                        <a href="{{ path('participant_show', {'id': participant.id}) }}" title="Détails participant">#}
{#                            {{ sortie.participant.pseudo }}#}
{#                        </a>#}
{#                    </td>#}
{#                    <td>{{ sortie.participant.Nom }}</td>#}
{#                </tr>#}
{#            {% else %}#}
{#                <tr>#}
{#                    <td colspan="5">Aucun participant trouvé</td>#}
{#                </tr>#}
{#            {% endfor %}#}
            <tr>
                <td>
                    <a href="">JBL / à faire</a>
                </td>
                <td>Jean-Baptiste LAMARCK / à faire</td>
            </tr>
            </tbody>
        </table>

    </div>

{% endblock %}


