{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }}{{ sortie.nom }}
{% endblock %}


{% block section %}
    <h1 class="text-center mb-4">Afficher une sortie</h1>

    <div class="d-flex justify-content-center align-items-center">
        <span class="badge {{ etatColor }}">{{ sortie.etat.libelle }}</span>
    </div>

    <!-- infos 2 colonnes -->
    <div class="container mt-5">

        <div class="card shadow-sm">
            <div class="card-body">

                <div class="row">

                    <!-- Colonne gauche -->
                    <div class="col-md-6">

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Nom de la sortie</div>
                            <div class="col-6">{{ sortie.nom }}</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Date et heure de la sortie</div>
                            <div class="col-6">
                                {{ sortie.dateHeureDebut|date('d/m/Y H:i') }}
                            </div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Date limite d'inscription</div>
                            <div class="col-6">
                                {{ sortie.dateLimiteInscription|date('d/m/Y H:i') }}
                            </div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Nombre de places</div>
                            <div class="col-6">{{ sortie.nbInscriptionMax }}</div>
                        </div>

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Durée (en minutes)</div>
                            <div class="col-6">{{ sortie.duree }}</div>
                        </div>

                    </div>

                    <!-- Colonne droite -->
                    <div class="col-md-6">

                        <div class="row mb-2">
                            <div class="col-6 fw-bold">Campus</div>
                            <div class="col-6">{{ sortie.campus.name }}</div>
                        </div>

                        {% for lieu in sortie.lieux %}
                            <div class="row mb-2">
                                <div class="col-6 fw-bold">Ville</div>
                                <div class="col-6">{{ lieu.codePostal.name }}</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-6 fw-bold">Lieu</div>
                                <div class="col-6">{{ lieu.name }}</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-6 fw-bold">Rue</div>
                                <div class="col-6">{{ lieu.rue }}</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-6 fw-bold">Code postal</div>
                                <div class="col-6">{{ lieu.codePostal.codePostal }}</div>
                            </div>

                            {% if lieu.coordonneesGps %}
                                <div class="row mb-2">
                                    <div class="col-6 fw-bold">Latitude / Longitude</div>
                                    <div class="col-6">{{ lieu.coordonneesGps }}</div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>

                </div>

                <!-- Description -->
                <hr>

                <div class="mt-3">
                    <h5>Description et infos</h5>
                    <p class="text-muted">
                        {{ sortie.infosSortie }}
                    </p>
                </div>

                <!-- Si Annulée -->
                {% if sortie.motif %}
                    <div class="alert alert-danger">
                        <strong>Motif d'annulation :</strong> {{ sortie.motif }}
                    </div>
                {% endif %}

            </div>
        </div>

    </div>

    <!-- liste participant -->
    <div class="container mt-5">
        <h2>Liste des participants inscrits</h2>
        <table class="table-sm table-bordered">
            <thead>
            <tr>
                <th scope="col">Pseudo</th>
                <th scope="col">Nom</th>
            </tr>
            </thead>
            <tbody>
            {% for participant in sortie.inscrits %}
                <tr>
                    <td>
                        <a href="{{ path('app_participant_read') }}" title="Détails participant">
                            {{ participant.pseudo }}
                        </a>
                    </td>
                    <td> {{ participant }} </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">Aucun participant trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

    </div>

{% endblock %}


