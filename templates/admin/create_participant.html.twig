{% extends 'base.html.twig' %}

{% block title %}{{parent()}}Créer participant{% endblock %}

{% block section %}
    <div class="justify-content-center">

        <div class="row">
            <h3 class="m-3 col text-center">Mon Profil</h3>
        </div>
        {{ form_start(formParticipant) }}
        {{ form_widget(formParticipant) }}
        <div class="d-flex justify-content-center gap-5">
            <button type="submit" class="btn btn-success">Valider</button>
            <button class="btn btn-secondary"><a href="{{ path('app_participant_read') }}" class="text-white text-decoration-none">Retour</a></button>
        </div>
        {{ form_end(formParticipant) }}
    </div>

{% endblock %}
