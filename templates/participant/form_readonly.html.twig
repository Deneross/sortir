<div class="col-sm-12 col-md-6 justify-content-start align-content-around">
    <div class="conainter text-center">
        <div class="row">
            <h3 class="m-3 col">{{ participant.pseudo }}</h3>
        </div>
        <div class="form-floating mb-3">
            <input type="text" readonly class="form-control-plaintext" id="participantCampus"
                   value="{{ participant.campus }}">
            <label for="participantCampus">Campus</label>
        </div>
        <div class="form-floating mb-3">
            <input type="text" readonly class="form-control-plaintext" id="participantPrenom"
                   value="{{ participant.prenom }}">
            <label for="participantPrenom">Prénom</label>
        </div>
        <div class="form-floating mb-3">
            <input type="text" readonly class="form-control-plaintext" id="participantNom"
                   value="{{ participant.nom }}">
            <label for="participantNom">Nom</label>
        </div>
        <div class="form-floating mb-3">
            <input type="tel" readonly class="form-control-plaintext" id="participantTelephone"
                   value="{{ participant.telephone }}">
            <label for="participantTelephone">Telephone</label>
        </div>
        <div class="form-floating mb-3">
            <input type="email" readonly class="form-control-plaintext" id="participantEmail"
                   value="{{ participant.mail }}">
            <label for="participantEmail">Email</label>
        </div>
        {% if app.user === participant %}
            <button class="btn">
                <a href="{{ path('app_participant_update') }}" class="btn btn-secondary">Modifier</a>
            </button>
        {% endif %}
    </div>
</div>
